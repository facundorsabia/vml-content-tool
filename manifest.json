{
  "manifest_version": 3,
  "name": "VML Content Tool",
  "version": "2.3",
  "description": "Suite de herramientas para Content Editors de VML.",
  "permissions": [
      "storage",
      "activeTab",
      "scripting",
      "webNavigation"
    ],
  "action": {
    "default_popup": "core/popup.html",
    "default_icon": "assets/logo-vml.png"
  },
  "icons": {
    "128": "assets/logo-vml.png"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "modules/nbsp/content-nbsp.js",
        "modules/finder/content-finder.js",
        "modules/autofiller/content-autofiller.js",
        "modules/htags/content-htags.js",
        "modules/dropdown/content-dropdown.js"
      ],
      "css": [
        "core/content.css"
      ],
      "all_frames": true
    }
  ]
}